# Copy to .env.local — never commit real keys.

# Server-side 0G Compute credentials (used by server/index.js proxy)
# Get key: https://pc.testnet.0g.ai → connect wallet → deposit testnet 0G → Dashboard → API Keys
OG_API_KEY=sk-your-key-here

# Testnet router (matches pc.testnet.0g.ai deposits)
OG_ROUTER_API=https://router-api-testnet.integratenetwork.work/v1

# Testnet chat model (GLM-5 is mainnet-only; testnet uses qwen2.5-omni)
OG_MODEL_ID=qwen2.5-omni

# For mainnet instead:
# OG_ROUTER_API=https://router-api.0g.ai/v1
# OG_MODEL_ID=zai-org/GLM-5-FP8

# Optional: API server port (default 3001)
# PORT=3001