# Copy to .env.local — never commit real keys.

# Server-side 0G Compute credentials (used by api/compute + server/index.js)
# REQUIRED on Vercel/Render — add as OG_API_KEY (not VITE_) in hosting dashboard
# Get key: https://pc.testnet.0g.ai → connect wallet → deposit testnet 0G → Dashboard → API Keys
OG_API_KEY=sk-your-key-here

# Testnet router (matches pc.testnet.0g.ai deposits)
OG_ROUTER_API=https://router-api-testnet.integratenetwork.work/v1

# Testnet chat model (GLM-5 is mainnet-only; testnet uses qwen2.5-omni)
OG_MODEL_ID=qwen2.5-omni

# For mainnet instead:
# OG_ROUTER_API=https://router-api.0g.ai/v1
# OG_MODEL_ID=zai-org/GLM-5-FP8

# Server wallet for 0G Storage uploads (HTTP nodes — proxied server-side on HTTPS)
# Export private key from a testnet wallet funded with 0G for storage fees
OG_STORAGE_PRIVATE_KEY=0x-your-testnet-wallet-private-key

# Optional: API server port (default 3001)
# PORT=3001

# PromptLedger contract — live on 0G Testnet (deployed by project author)
VITE_PROMPT_LEDGER_ADDRESS=0xb6aedBF17a11928A63773F88a9CfD3E252F43a63