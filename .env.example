# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# 0G Compute Router API key (starts with sk-)
# 1. Go to https://pc.testnet.0g.ai
# 2. Connect wallet, deposit testnet 0G
# 3. Dashboard → API Keys → Create → copy the sk- key once
VITE_0G_API_KEY=sk-your-key-here

# Router endpoint — must match where you deposited:
# Testnet (default): https://router-api-testnet.integratenetwork.work/v1
# Mainnet:           https://router-api.0g.ai/v1
VITE_0G_ROUTER_API=https://router-api-testnet.integratenetwork.work/v1